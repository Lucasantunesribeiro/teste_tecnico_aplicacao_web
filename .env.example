# Database
DB_HOST=localhost
DB_PORT=5432
DB_HOST_PORT=15432
DB_NAME=usuarios_db
DB_USER=postgres
DB_PASS=postgres

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6380
# Required in production compose
REDIS_PASSWORD=<YOUR_REDIS_PASSWORD>

# JWT
# Development default only. Replace in production with: openssl rand -base64 64
JWT_SECRET=ZGV2LWp3dC1zZWNyZXQtZm9yLWxvY2FsLXRlc3Rpbmctb25seS1yZXBsYWNlLWluLXByb2Q=
JWT_EXPIRATION=86400000
BACKEND_HOST_PORT=8081
FRONTEND_HOST_PORT=8088

# Logging
LOG_LEVEL=INFO
JPA_SHOW_SQL=false

# Security
TRUST_PROXY_HEADERS=false
