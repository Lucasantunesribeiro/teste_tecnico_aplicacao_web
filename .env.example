# Database
DB_HOST=<YOUR_DB_HOST>
DB_PORT=5432
DB_NAME=usuarios_db
DB_USER=<YOUR_DB_USER>
DB_PASS=<YOUR_DB_PASSWORD>

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT (generate with: openssl rand -base64 64)
JWT_SECRET=<YOUR_JWT_SECRET_BASE64_MIN_256_BITS>
JWT_EXPIRATION=86400000

# Logging
LOG_LEVEL=INFO
JPA_SHOW_SQL=false
