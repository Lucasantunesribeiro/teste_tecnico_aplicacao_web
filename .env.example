# Database
DB_HOST=localhost
DB_PORT=5432
DB_HOST_PORT=15432
DB_NAME=usuarios_db
DB_USER=postgres
DB_PASS=postgres

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6380
# Required in production compose
REDIS_PASSWORD=<YOUR_REDIS_PASSWORD>

# JWT
# Development default only. Replace in production with: openssl rand -base64 64
JWT_SECRET=ZGV2LWp3dC1zZWNyZXQtZm9yLWxvY2FsLXRlc3Rpbmctb25seS1yZXBsYWNlLWluLXByb2Q=
# Access token expiration (ms) — default 15 minutes
JWT_ACCESS_EXPIRATION=900000
# Refresh token expiration (ms) — default 7 days
JWT_REFRESH_EXPIRATION=604800000

# Host ports (change only if 8080 or 80 are already in use on your machine)
BACKEND_HOST_PORT=8080
FRONTEND_HOST_PORT=80

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost

# Logging
LOG_LEVEL=INFO
JPA_SHOW_SQL=false

# Security
# Set to true only when running behind a trusted reverse proxy that sets X-Forwarded-For
TRUST_PROXY_HEADERS=false
